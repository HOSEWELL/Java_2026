pipeline {
    agent any

    tools {
        // This tells Jenkins to use the Java version you have installed
        jdk 'jdk21' 
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📥 Pulling code from GitHub...'
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                echo '⚙️ Compiling Java source code...'
                // If you have Maven installed on your Lenovo, we use 'mvn'
                sh './mvnw clean compile' 
            }
        }

        stage('Run Tests') {
            steps {
                echo '🧪 Running Unit Tests (JUnit)...'
                // This specifically runs files like your AppTest.java
                sh './mvnw test'
            }
        }

        stage('Package') {
            steps {
                echo '📦 Packaging application into a JAR file...'
                sh './mvnw package -DskipTests'
            }
        }
    }

    post {
        success {
            echo '✅ Build and Tests passed successfully!'
        }
        failure {
            echo '❌ Build failed. Check the Console Output for errors.'
        }
    }
}